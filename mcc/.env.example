# ====== MCC Environment Variables Template ======
# 复制此文件为 .env 并填入实际值

# Server
MCC_SERVER_PORT=3000
MCC_NODE_ENV=development

# Redis (Active Memory 主存储)
MCC_REDIS_HOST=localhost
MCC_REDIS_PORT=6379
MCC_REDIS_PASSWORD=

# PostgreSQL (Phase 1A.2 启用)
# MCC_PG_HOST=localhost
# MCC_PG_PORT=5432
# MCC_PG_USER=mcc_user
# MCC_PG_PASSWORD=change_me
# MCC_PG_DATABASE=mcc

# Ollama Embedding (Phase 1A.2 启用)
# MCC_OLLAMA_URL=http://localhost:11434
# MCC_OLLAMA_MODEL_EMBED=nomic-embed-text

# JWT Authentication (Phase 1B 启用)
# MCC_JWT_SECRET=generate_a_random_secret_at_least_64_chars
# MCC_JWT_REFRESH_SECRET=generate_another_random_secret

# LLM API Keys (按需配置，至少配一个)
# MCC_KIMI_API_KEY=
# MCC_OPENAI_API_KEY=
# MCC_ANTHROPIC_API_KEY=

# Logging
MCC_LOG_LEVEL=debug
